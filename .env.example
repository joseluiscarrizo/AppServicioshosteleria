# ==============================================
# Camareros Bcn — Variables de Entorno
# ==============================================
# Copia este archivo como .env y completa los valores:
#   cp .env.example .env
#
# IMPORTANTE: Nunca subas el archivo .env a git.
# Las variables VITE_* son expuestas al navegador (frontend).
# ==============================================

# ── Base44 BaaS (REQUERIDAS para arrancar la app) ──
# Obtén estos valores en: Base44 Dashboard → Settings → API Keys
VITE_BASE44_APP_ID=your_base44_app_id_here
VITE_BASE44_BACKEND_URL=https://api.base44.com

# ── Entorno ────────────────────────────────────────
NODE_ENV=development

# ── WhatsApp Business API ──────────────────────────
# Requeridas en las Cloud Functions para envío directo vía WhatsApp Business API.
# Sin estas variables la app usa WhatsApp Web (wa.me) como fallback automático.
# Obtén el token en: Meta for Developers → WhatsApp → API Setup
# WHATSAPP_API_TOKEN=your_whatsapp_bearer_token
# WHATSAPP_PHONE_NUMBER=your_phone_number_id   # ID numérico del número registrado

# ── Gmail SMTP (opcional) ──────────────────────────
# GMAIL_USER=tu_email@gmail.com
# GMAIL_PASS=tu_app_password_de_16_caracteres

# ── Google Sheets API (opcional) ───────────────────
# GOOGLE_SERVICE_ACCOUNT_EMAIL=service-account@proyecto.iam.gserviceaccount.com
# GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
# GOOGLE_SPREADSHEET_ID=your_spreadsheet_id