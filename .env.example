# ── Base44 BaaS (REQUERIDO) ──────────────────────────────────────
VITE_BASE44_APP_ID=your_app_id_here
VITE_BASE44_BACKEND_URL=https://api.base44.com

# ── Servicios opcionales ─────────────────────────────────────────
# WhatsApp Business API
WHATSAPP_TOKEN=your_whatsapp_token_here
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id_here

# Gmail / Google Workspace
GMAIL_CLIENT_ID=your_gmail_client_id_here
GMAIL_CLIENT_SECRET=your_gmail_client_secret_here
GMAIL_REFRESH_TOKEN=your_gmail_refresh_token_here
GMAIL_FROM_EMAIL=noreply@camarerosbcn.es

# Google Sheets (exportación de reportes)
GOOGLE_SHEETS_API_KEY=your_google_sheets_api_key_here

# ── CORS ─────────────────────────────────────────────────────────
# URL del frontend en producción (para CORS en Cloud Functions)
ALLOWED_ORIGIN=https://tu-dominio.netlify.app
