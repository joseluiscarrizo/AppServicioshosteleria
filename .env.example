# ==============================================
# Camareros Bcn — Variables de Entorno
# ==============================================
# Copia este archivo como .env y completa los valores:
#   cp .env.example .env
#
# IMPORTANTE: Nunca subas el archivo .env a git.
# Las variables VITE_* son expuestas al navegador (frontend).
# ==============================================

# ── Base44 BaaS (REQUERIDAS para arrancar la app) ──
VITE_BASE44_APP_ID=your_base44_app_id_here
VITE_BASE44_BACKEND_URL=https://api.base44.com

# ── Base44 Vite Plugin — Proxy local (opcional) ────
# Si usas @base44/vite-plugin, define esta URL para habilitar el proxy
# /api → VITE_BASE44_APP_BASE_URL en el servidor de desarrollo.
# Sin ella, el plugin imprimirá "Proxy not enabled" (el servidor sigue funcionando).
# VITE_BASE44_APP_BASE_URL=https://api.base44.com

# ── Entorno ────────────────────────────────────────
NODE_ENV=development

# ── WhatsApp Business API (opcional) ───────────────
# Configura estas variables en el backend de Base44 (Cloud Functions → Secrets),
# NO en el archivo .env del frontend. Sin ellas, el sistema usa WhatsApp Web como
# fallback abriendo ventanas para envío manual.
# WHATSAPP_API_TOKEN=your_whatsapp_bearer_token        (Meta / Graph API bearer token)
# WHATSAPP_PHONE_NUMBER=your_phone_number_id           (ID del número en Meta Business)

# ── Gmail SMTP (opcional) ──────────────────────────
# GMAIL_USER=tu_email@gmail.com
# GMAIL_PASS=tu_app_password_de_16_caracteres

# ── Google Sheets API (opcional) ───────────────────
# GOOGLE_SERVICE_ACCOUNT_EMAIL=service-account@proyecto.iam.gserviceaccount.com
# GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
# GOOGLE_SPREADSHEET_ID=your_spreadsheet_id